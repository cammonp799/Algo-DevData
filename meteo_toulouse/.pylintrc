[MASTER]
load-plugins=pylint.extensions.docparams
ignore=tests

[MESSAGES CONTROL]
disable=
    missing-docstring,
    too-few-public-methods,
    invalid-name,

[FORMAT]
max-line-length=100
indent-string='    '

[BASIC]
good-names=i,j,k,ex,Run,_,id,x,y,z,df,db

[DESIGN]
max-locals=15
max-branches=12
max-attributes=7
